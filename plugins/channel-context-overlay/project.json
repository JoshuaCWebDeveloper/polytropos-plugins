{
  "name": "channel-context-overlay",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "plugins/channel-context-overlay",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "plugins/channel-context-overlay",
        "command": "pnpm run build"
      }
    },
    "deploy-dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node scripts/deploy-plugin.mjs symlink dist/plugins/channel-context-overlay channel-context-overlay"
      }
    },
    "deploy-prod": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node scripts/deploy-plugin.mjs copy dist/plugins/channel-context-overlay channel-context-overlay"
      }
    }
  }
}
