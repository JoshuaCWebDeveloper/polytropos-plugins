{
  "name": "exec-background",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "plugins/exec-background/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "plugins/exec-background",
        "command": "pnpm run build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "plugins/exec-background",
        "command": "pnpm run test"
      }
    },
    "deploy-dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node scripts/deploy-plugin.mjs symlink dist/plugins/exec-background exec-background"
      }
    },
    "deploy-prod": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node scripts/deploy-plugin.mjs copy dist/plugins/exec-background exec-background"
      }
    }
  }
}
