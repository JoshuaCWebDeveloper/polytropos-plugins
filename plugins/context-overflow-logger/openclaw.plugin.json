{
  "id": "context-overflow-logger",
  "name": "Context Overflow Logger",
  "description": "Adds diagnostic logging when OpenClaw classifies an error as context overflow.",
  "version": "0.0.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "dryRun": {
        "type": "boolean",
        "default": false
      }
    }
  },
  "entry": "dist/index.js"
}
